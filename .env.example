# =================================
# Database
# =================================
DATABASE_URL="postgresql://hardgraph:hardgraph_dev@localhost:5432/hardgraph?schema=public"
POSTGRES_USER=hardgraph
POSTGRES_PASSWORD=hardgraph_dev
POSTGRES_DB=hardgraph

# =================================
# Auth
# =================================
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# GitHub OAuth (required for "Continue with GitHub" to work)
# Get these from: https://github.com/settings/developers → OAuth Apps
# IMPORTANT: "Authorization callback URL" in GitHub MUST exactly match GITHUB_CALLBACK_URL below
GITHUB_CLIENT_ID=Ov23li...your_client_id
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# =================================
# App
# =================================
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =================================
# Email (SMTP) — optional for dev, emails logged to console if not set
# =================================
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=your_smtp_api_key
# SMTP_FROM=HardGraph <noreply@yourdomain.com>

# =================================
# AI (enables AI vacancy analysis, HR advisor, and smart matching)
# Get your key from: https://platform.openai.com/api-keys
# =================================
OPENAI_API_KEY=sk-...
