# =================================
# Database
# =================================
DATABASE_URL="postgresql://skillgraph:skillgraph_dev@localhost:5432/skillgraph?schema=public"
POSTGRES_USER=skillgraph
POSTGRES_PASSWORD=skillgraph_dev
POSTGRES_DB=skillgraph

# =================================
# Auth
# =================================
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# =================================
# App
# =================================
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
