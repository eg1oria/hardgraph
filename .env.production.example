# =================================
# Production Environment
# =================================
# Copy to .env.production and fill in real values.
# Used by docker-compose.prod.yml

NODE_ENV=production

# Database
POSTGRES_USER=skillgraph
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=skillgraph
DATABASE_URL=postgresql://skillgraph:CHANGE_ME_STRONG_PASSWORD@postgres:5432/skillgraph?schema=public

# Auth
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.skillgraph.io/api/auth/github/callback

# URLs — set to your actual domain
API_PORT=4000
NEXT_PUBLIC_API_URL=https://api.skillgraph.io
NEXT_PUBLIC_APP_URL=https://skillgraph.io
