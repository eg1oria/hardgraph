# =================================
# Production Environment
# =================================
# Copy to .env and fill in real values before deployment.
# Used by docker-compose.prod.yml

NODE_ENV=production

# Database
POSTGRES_USER=hardgraph
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=hardgraph
DATABASE_URL=postgresql://hardgraph:CHANGE_ME_STRONG_PASSWORD@postgres:5432/hardgraph?schema=public

# Auth
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d

# GitHub OAuth (optional — leave empty to disable GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://YOUR_DOMAIN/api/auth/github/callback

# URLs — set to your actual domain
# IMPORTANT: NEXT_PUBLIC_API_URL must include /api suffix
API_PORT=4000
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN/api
NEXT_PUBLIC_APP_URL=https://YOUR_DOMAIN

# Email (SMTP) — required for email verification
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=CHANGE_ME_SMTP_API_KEY
SMTP_FROM=HardGraph <noreply@YOUR_DOMAIN>
