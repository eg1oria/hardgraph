generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(uuid()) @db.Uuid
  email                String   @unique @db.VarChar(255)
  passwordHash         String?  @map("password_hash") @db.VarChar(255)
  username             String   @unique @db.VarChar(50)
  displayName          String?  @map("display_name") @db.VarChar(100)
  bio                  String?
  avatarUrl            String?  @map("avatar_url") @db.VarChar(500)
  githubId             String?  @map("github_id") @db.VarChar(100)
  githubUsername       String?  @map("github_username") @db.VarChar(100)
  githubAccessToken    String?  @map("github_access_token") @db.VarChar(500)
  websiteUrl           String?  @map("website_url") @db.VarChar(500)
  twitterHandle        String?  @map("twitter_handle") @db.VarChar(100)
  linkedinUrl          String?  @map("linkedin_url") @db.VarChar(500)
  role                 String   @default("user") @db.VarChar(20)
  plan                 String   @default("free") @db.VarChar(20)
  stripeCustomerId     String?  @map("stripe_customer_id") @db.VarChar(100)
  stripeSubscriptionId String?  @map("stripe_subscription_id") @db.VarChar(100)
  emailVerified        Boolean  @default(false) @map("email_verified")
  emailVerifiedAt      DateTime? @map("email_verified_at")
  onboardingCompleted  Boolean  @default(false) @map("onboarding_completed")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  graphs                 Graph[]
  stories                Story[]
  vacancies              Vacancy[]
  emailVerificationTokens EmailVerificationToken[]

  @@index([username])
  @@map("users")
}

model Graph {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  title        String   @db.VarChar(200)
  slug         String   @db.VarChar(200)
  description  String?
  field        String?  @db.VarChar(100)
  isPublic     Boolean  @default(true) @map("is_public")
  isPrimary    Boolean  @default(false) @map("is_primary")
  theme        String   @default("cyberpunk") @db.VarChar(50)
  customStyles Json     @default("{}") @map("custom_styles")
  viewport     Json     @default("{}") @map("viewport")
  viewCount         Int      @default(0) @map("view_count")
  forkedFromId     String?  @map("forked_from_id") @db.Uuid
  forkCount        Int      @default(0) @map("fork_count")
  endorsementCount Int      @default(0) @map("endorsement_count")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  forkedFrom   Graph?        @relation("GraphForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks        Graph[]       @relation("GraphForks")
  categories   Category[]
  nodes        Node[]
  edges        Edge[]
  profileViews ProfileView[]
  endorsements Endorsement[]
  stories      Story[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([isPublic, createdAt])
  @@map("graphs")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  graphId   String   @map("graph_id") @db.Uuid
  name      String   @db.VarChar(100)
  color     String?  @db.VarChar(7)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  graph Graph  @relation(fields: [graphId], references: [id], onDelete: Cascade)
  nodes Node[]

  @@index([graphId])
  @@map("categories")
}

model Node {
  id            String   @id @default(uuid()) @db.Uuid
  graphId       String   @map("graph_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  parentIdeaId  String?  @map("parent_idea_id") @db.Uuid
  name          String   @db.VarChar(150)
  description   String?
  level         String   @default("beginner") @db.VarChar(20)
  nodeType      String   @default("skill") @map("node_type") @db.VarChar(30)
  icon          String?  @db.VarChar(100)
  positionX     Float    @default(0) @map("position_x")
  positionY     Float    @default(0) @map("position_y")
  customData        Json     @default("{}") @map("custom_data")
  isUnlocked        Boolean  @default(true) @map("is_unlocked")
  endorsementCount  Int      @default(0) @map("endorsement_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  graph         Graph         @relation(fields: [graphId], references: [id], onDelete: Cascade)
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parentIdea    Node?         @relation("IdeaEvolution", fields: [parentIdeaId], references: [id], onDelete: SetNull)
  childIdeas    Node[]        @relation("IdeaEvolution")
  sourceEdges   Edge[]        @relation("SourceNode")
  targetEdges   Edge[]        @relation("TargetNode")
  endorsements  Endorsement[]

  @@index([graphId])
  @@index([categoryId])
  @@index([parentIdeaId])
  @@map("nodes")
}

model Edge {
  id           String   @id @default(uuid()) @db.Uuid
  graphId      String   @map("graph_id") @db.Uuid
  sourceNodeId String   @map("source_node_id") @db.Uuid
  targetNodeId String   @map("target_node_id") @db.Uuid
  label        String?  @db.VarChar(100)
  edgeType     String   @default("default") @map("edge_type") @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at")

  graph      Graph @relation(fields: [graphId], references: [id], onDelete: Cascade)
  sourceNode Node  @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode Node  @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId])
  @@index([graphId])
  @@map("edges")
}

model Template {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  description String?
  field       String?  @db.VarChar(100)
  graphData   Json     @map("graph_data")
  usageCount  Int      @default(0) @map("usage_count")
  isFeatured  Boolean  @default(false) @map("is_featured")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("templates")
}

model ProfileView {
  id           String   @id @default(uuid()) @db.Uuid
  graphId      String   @map("graph_id") @db.Uuid
  viewerIpHash String?  @map("viewer_ip_hash") @db.VarChar(64)
  viewerUserId String?  @map("viewer_user_id") @db.Uuid
  referrer     String?  @db.VarChar(500)
  country      String?  @db.VarChar(5)
  viewedAt     DateTime @default(now()) @map("viewed_at")

  graph Graph @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@index([graphId])
  @@index([viewedAt])
  @@index([graphId, viewerIpHash, viewedAt])
  @@map("profile_views")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("email_verification_tokens")
}

model Endorsement {
  id        String   @id @default(uuid()) @db.Uuid
  nodeId    String   @map("node_id") @db.Uuid
  graphId   String   @map("graph_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  node  Node  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  graph Graph @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@unique([nodeId, userId])
  @@unique([nodeId, ipHash])
  @@index([graphId])
  @@index([nodeId])
  @@map("endorsements")
}

model Story {
  id           String    @id @default(uuid()) @db.Uuid
  authorId     String    @map("author_id") @db.Uuid
  title        String    @db.VarChar(300)
  slug         String    @db.VarChar(300)
  content      String
  excerpt      String?   @db.VarChar(500)
  coverUrl     String?   @map("cover_url") @db.VarChar(500)
  category     String    @db.VarChar(50)
  tags         String[]  @default([])
  field        String?   @db.VarChar(100)
  isPublished  Boolean   @default(false) @map("is_published")
  viewCount    Int       @default(0) @map("view_count")
  likeCount    Int       @default(0) @map("like_count")
  commentCount Int       @default(0) @map("comment_count")
  readTime     Int       @default(0) @map("read_time")
  graphId      String?   @map("graph_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  publishedAt  DateTime? @map("published_at")

  author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  graph    Graph?         @relation(fields: [graphId], references: [id], onDelete: SetNull)
  likes    StoryLike[]
  comments StoryComment[]

  @@unique([authorId, slug])
  @@index([authorId])
  @@index([isPublished, publishedAt])
  @@index([category])
  @@index([field])
  @@map("stories")
}

model StoryLike {
  id        String   @id @default(uuid()) @db.Uuid
  storyId   String   @map("story_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@unique([storyId, ipHash])
  @@index([storyId])
  @@map("story_likes")
}

model Vacancy {
  id          String   @id @default(uuid()) @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  title       String   @db.VarChar(200)
  company     String?  @db.VarChar(200)
  description String?
  field       String?  @db.VarChar(100)
  location    String?  @db.VarChar(200)
  salaryRange String?  @map("salary_range") @db.VarChar(100)
  skills      Json     @default("[]") // [{name, level, category?, categoryColor?}]
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([isActive])
  @@map("vacancies")
}

model StoryComment {
  id        String   @id @default(uuid()) @db.Uuid
  storyId   String   @map("story_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  story   Story          @relation(fields: [storyId], references: [id], onDelete: Cascade)
  parent  StoryComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies StoryComment[] @relation("CommentReplies")

  @@index([storyId])
  @@index([parentId])
  @@map("story_comments")
}
