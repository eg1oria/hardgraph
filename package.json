{
  "name": "hardgraph",
  "version": "0.1.0",
  "private": true,
  "description": "HardGraph — interactive skill tree builder",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @hardgraph/web dev",
    "dev:api": "pnpm --filter @hardgraph/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @hardgraph/web build",
    "build:api": "pnpm --filter @hardgraph/api build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @hardgraph/api prisma:generate",
    "db:migrate": "pnpm --filter @hardgraph/api prisma:migrate",
    "db:studio": "pnpm --filter @hardgraph/api prisma:studio",
    "clean": "pnpm -r exec -- rimraf dist .next .turbo node_modules/.cache"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@nestjs/core",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint-config-prettier": "^9.1.2"
  }
}
